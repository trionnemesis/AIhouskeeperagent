# 複製為 .env（**勿入版控**，已被 .gitignore 的 .env 規則涵蓋）。值由密管/手動注入。
TENANT_ID=tenant-demo
HERMES_PINNED_TAG=v0.0.0-pinned

# 資料層（VM 內部）
PG_USER=hermes
PG_PASSWORD=__set_me__
REDIS_PASSWORD=__set_me__

# LINE（SEC-4；fastapi-edge / caddy 需要）
LINE_CHANNEL_SECRET=__set_me__
LINE_CHANNEL_ACCESS_TOKEN=__set_me__

# caddy webhook 網域（指向本 VM 的靜態 IP；LINE Developer Console 設此）
WEBHOOK_DOMAIN=hermes.example.com
